# 复制本文件为 .env 后修改（.env 不会提交到 Git）

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=sysmldocgen

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Storage
UPLOAD_DIR=./storage
STORAGE_MODEL_DIR=./storage/models

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
